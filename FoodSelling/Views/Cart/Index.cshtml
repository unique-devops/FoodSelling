@model IEnumerable<CartItem>

<table>
    <thead>
        <tr>
            <th>Product Name</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ProductName</td>
                <td>@item.Price</td>
                <td>@item.Quantity</td>
                <td>
                    
                    <a href="@Url.Action("RemoveFromCart", "Cart", new { productId = item.ProductId })">Remove</a>
                    <a href="@Url.Action("UpdateCart", "Cart", new { productId = item.ProductId })">Qty(+)</a>
                    <a href="@Url.Action("UpdateCart", "Cart", new { productId = item.ProductId })">Qty(-)</a>                   
                </td>
            </tr>
        }
    </tbody>
</table>